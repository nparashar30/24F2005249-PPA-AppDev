FLASK_ENV=development
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-key

# Admin seed
ADMIN_EMAIL=admin@institute.edu
ADMIN_PASSWORD=admin123

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Email (optional – for reminders & reports)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@placementportal.edu
ADMIN_REPORT_EMAIL=admin@institute.edu

# Google Chat webhook (optional)
GCHAT_WEBHOOK_URL=

# Cache TTL (seconds)
CACHE_DEFAULT_TTL=300
